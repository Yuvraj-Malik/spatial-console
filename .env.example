# Spatial Console - Environment Keys Template
# Copy this file to '.env' for local development.
# In Netlify, set these under Site configuration > Environment variables.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Frontend app domain
VITE_APP_URL=https://yuvrajm.dev

# Backend API domain (Render custom domain)
VITE_API_BASE_URL=https://spatial-console.yuvrajm.dev
